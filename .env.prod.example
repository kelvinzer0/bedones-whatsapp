# =============================================================================
# BEDONES WHATSAPP - Standalone Production Environment
# =============================================================================
# Copy this file to .env.prod and edit values before running:
#   cp .env.prod.example .env.prod
#   nano .env.prod  # edit values
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (shared by backend + agent, 2 databases auto-created)
# -----------------------------------------------------------------------------
POSTGRES_USER=bedones
POSTGRES_PASSWORD=change-me-to-a-strong-password

# -----------------------------------------------------------------------------
# Public URL configuration
# -----------------------------------------------------------------------------

# Where your backend is reachable from the internet (e.g. https://api.yourdomain.com)
# If testing locally: http://localhost:3000
BACKEND_URL=http://localhost:3000

# Port to expose backend on the host
BACKEND_PORT=3000

# Where your frontend is hosted (Cloudflare Workers URL or your own domain)
# This is used for CORS and redirect URLs
FRONTEND_URL=https://chat-bedones.insidexofficial.workers.dev

# -----------------------------------------------------------------------------
# JWT & encryption secrets
# -----------------------------------------------------------------------------
# IMPORTANT: Generate strong random strings for each secret!
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=replace-with-32-char-random-hex-string
JWT_EXPIRES_IN=7d
QR_JWT_SECRET=replace-with-32-char-random-hex-string
AGENT_INTERNAL_JWT_SECRET=replace-with-32-char-random-hex-string
ENCRYPTION_KEY=replace-with-exactly-32-chars-string

# -----------------------------------------------------------------------------
# WhatsApp Connector
# -----------------------------------------------------------------------------
# Secret used to sign webhooks between connector and backend (must match backend)
CONNECTOR_SECRET=replace-with-32-char-random-hex-string
# Unique identifier for this connector instance
CONNECTOR_INSTANCE_ID=bedones-wa-local
# Auto-start WhatsApp session on boot (true = show QR code immediately)
WHATSAPP_AUTOSTART=true
WPPCONNECT_SECRET_KEY=THISISMYSECURETOKEN

# Ports to expose on host
CONNECTOR_PORT=3001
AGENT_PORT=3002

# -----------------------------------------------------------------------------
# AI Providers (at least one is required)
# -----------------------------------------------------------------------------

# xAI Grok (primary or fallback)
# Get key: https://console.x.ai/
XAI_API_KEY=
XAI_MODEL=grok-3

# Google Gemini (primary or fallback, also used for embeddings & vision)
# Get key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Which model to try first (gemini or grok)
PRIMARY_MODEL=gemini
FALLBACK_MODEL=grok

# -----------------------------------------------------------------------------
# Agent Backend Token (generate AFTER first run - see deploy/README.md)
# -----------------------------------------------------------------------------
# Leave empty for first run. After backend is up, generate token and restart
# whatsapp-agent service with the token set here.
AGENT_BACKEND_TOKEN=

# -----------------------------------------------------------------------------
# Minio / S3 (optional - for image storage features)
# -----------------------------------------------------------------------------
# Leave empty to disable. Required for catalog image upload.
MINIO_ENDPOINT=
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=whatsapp-agent

# -----------------------------------------------------------------------------
# Payment providers (optional - for billing features)
# -----------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

NOTCH_PUBLIC_KEY=
NOTCH_PRIVATE_KEY=
NOTCH_HASH_KEY=
